using Microsoft.EntityFrameworkCore;
using TodoApi.Models;

namespace TodoApi.Data;

public class AppDbContext : DbContext
{
    public AppDbContext(DbContextOptions<AppDbContext> options) : base(options) { }

    // Each DbSet = one table in the database
    public DbSet<User> Users { get; set; }
    public DbSet<TodoItem> TodoItems { get; set; }

    protected override void OnModelCreating(ModelBuilder modelBuilder)
    {
        base.OnModelCreating(modelBuilder);

        // User table rules
        modelBuilder.Entity<User>(entity =>
        {
            entity.HasKey(u => u.Id);

            entity.HasIndex(u => u.Email)
                  .IsUnique();               // no two users can share the same email

            entity.Property(u => u.Email)
                  .IsRequired()
                  .HasMaxLength(254);

            entity.Property(u => u.DisplayName)
                  .HasMaxLength(100);
        });

        // TodoItem table rules
        modelBuilder.Entity<TodoItem>(entity =>
        {
            entity.HasKey(t => t.Id);

            entity.Property(t => t.Title)
                  .IsRequired()
                  .HasMaxLength(100);

            entity.Property(t => t.Details)
                  .HasMaxLength(1000);

            entity.Property(t => t.Priority)
                  .HasConversion<string>()   // store "low"/"medium"/"high" as text, not a number
                  .IsRequired();

            // One User has many TodoItems
            // If a User is deleted, all their todos are deleted too
            entity.HasOne(t => t.User)
                  .WithMany(u => u.Todos)
                  .HasForeignKey(t => t.UserId)
                  .OnDelete(DeleteBehavior.Cascade);
        });
    }
}